Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories directly (JS, CSS, images, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ── Public dynamic routes ──────────────────────────────────────────────
  # New products, blogs, categories added after build are served via
  # the __placeholder__ shell; the client component reads the real ID from
  # the URL via useUrlParam() (usePathname()-based — useParams() reflects
  # the build-time placeholder, not the real URL) and fetches live data
  # from the API.

  RewriteRule ^product/([^/]+)/?$ /product/__placeholder__/index.html [L]
  RewriteRule ^blog/([^/]+)/?$ /blog/__placeholder__/index.html [L]
  RewriteRule ^category/([^/]+)/([^/]+)/?$ /category/__placeholder__/__placeholder__/index.html [L]
  RewriteRule ^category/([^/]+)/?$ /category/__placeholder__/index.html [L]
  RewriteRule ^barcode/([^/]+)/?$ /barcode/__placeholder__/index.html [L]
  RewriteRule ^scan/([^/]+)/?$ /scan/__placeholder__/index.html [L]
  RewriteRule ^tag/([^/]+)/?$ /tag/best-seller/index.html [L]
  RewriteRule ^cart/shared/([^/]+)/?$ /cart/shared/__placeholder__/index.html [L]

  # ── Dashboard dynamic routes ───────────────────────────────────────────
  # Sub-routes first (more specific before less specific)
  RewriteRule ^dashboard/orders/([^/]+)/invoice/?$ /dashboard/orders/__placeholder__/invoice/index.html [L]
  RewriteRule ^dashboard/orders/([^/]+)/slip/?$ /dashboard/orders/__placeholder__/slip/index.html [L]
  RewriteRule ^dashboard/orders/([^/]+)/?$ /dashboard/orders/__placeholder__/index.html [L]
  RewriteRule ^dashboard/products/([^/]+)/?$ /dashboard/products/__placeholder__/index.html [L]
  RewriteRule ^dashboard/blog/([^/]+)/?$ /dashboard/blog/__placeholder__/index.html [L]
  RewriteRule ^dashboard/categories/([^/]+)/?$ /dashboard/categories/__placeholder__/index.html [L]
  RewriteRule ^dashboard/customers/([^/]+)/profile/?$ /dashboard/customers/__placeholder__/profile/index.html [L]
  RewriteRule ^dashboard/customers/([^/]+)/?$ /dashboard/customers/__placeholder__/index.html [L]
  RewriteRule ^dashboard/authorized/([^/]+)/profile/?$ /dashboard/authorized/__placeholder__/profile/index.html [L]
  RewriteRule ^dashboard/authorized/([^/]+)/?$ /dashboard/authorized/__placeholder__/index.html [L]
  RewriteRule ^dashboard/customer-tags/([^/]+)/?$ /dashboard/customer-tags/__placeholder__/index.html [L]

  # ── User dynamic routes ────────────────────────────────────────────────
  RewriteRule ^user/orders/([^/]+)/invoice/?$ /user/orders/__placeholder__/invoice/index.html [L]

  # Fallback for any remaining unknown routes
  RewriteRule ^ index.html [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/xml application/xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# Custom 404
ErrorDocument 404 /404/index.html
